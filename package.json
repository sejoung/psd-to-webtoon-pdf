{
  "name": "psd-to-webtoon-pdf",
  "version": "0.2.0",
  "private": true,
  "description": "Convert multiple PSD files into a continuous PDF for easy review.",
  "license": "Apache-2.0",
  "author": "sejoung kim (https://github.com/sejoung)",
  "main": "./out/main/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:test",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "npm run build && vitest run --config vitest.integration.config.ts",
    "test:all": "npm run test && npm run test:integration",
    "verify": "npm run check && npm run typecheck && npm run test:all",
    "build:icons": "node scripts/build-icons.mjs",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "package:dir": "npm run build && electron-builder --dir",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@napi-rs/canvas": "^0.1.99",
    "ag-psd": "^30.1.1",
    "electron-log": "^5.4.3",
    "lucide-react": "^1.9.0",
    "pdfkit": "^0.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
